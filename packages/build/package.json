{
    "name": "@silkweaver/build",
    "version": "0.2.6",
    "description": "Silkweaver toolchain — compiles a project folder into a runnable game (HTML5 / desktop executable). Usable from a CLI or the IDE.",
    "type": "commonjs",
    "license": "GPL-3.0",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "assets"
    ],
    "scripts": {
        "build": "tsc -p ."
    },
    "dependencies": {
        "@silkweaver/engine": "0.2.6",
        "@silkweaver/project": "0.2.6",
        "@electron/packager": "^19.0.5",
        "esbuild": "^0.27.2",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "electron": "*"
    },
    "peerDependenciesMeta": {
        "electron": {
            "optional": true
        }
    }
}
